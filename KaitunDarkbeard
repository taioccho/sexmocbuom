-- ============================================================
-- HỆ THỐNG TỰ ĐỘNG HOP SERVER QUA REPLICATED KHI BỊ KICK
-- ============================================================
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local GuiService = game:GetService("GuiService")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local PlaceId = game.PlaceId

local isHopping = false

local function LocalServerHop()
    if isHopping then return end
    isHopping = true

    pcall(function()
        local UI = CoreGui:FindFirstChild("AutoChest")
        if UI and UI:FindFirstChild("Holder") and UI.Holder.Shadow:FindFirstChild("MainBoard") then
            UI.Holder.Shadow.MainBoard.Subtitle.Text = "Status: [ Hopping Server... ]"
        end
    end)

    local success, result = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
    end)
    
    if success and result then
        local servers = HttpService:JSONDecode(result)
        local available = {}
        for _, s in pairs(servers.data) do
            if s.playing and s.maxPlayers and s.playing < s.maxPlayers and s.id ~= game.JobId then
                table.insert(available, s.id)
            end
        end
        if #available > 0 then
            local randomJobId = available[math.random(1, #available)]
            pcall(function()
                ReplicatedStorage.__ServerBrowser:InvokeServer("teleport", randomJobId)
            end)
            return
        end
    end
    pcall(function() game:GetService("TeleportService"):Teleport(PlaceId, LocalPlayer) end)
end

-- 1. Bắt lỗi từ GuiService
GuiService.ErrorMessageChanged:Connect(function()
    if GuiService:GetErrorCode().Value > 0 then
        LocalServerHop()
    end
end)

-- 2. Bộ quét liên tục (Heartbeat) kiểm tra bảng báo lỗi xám
local PromptConnection
PromptConnection = RunService.Heartbeat:Connect(function()
    local promptGui = CoreGui:FindFirstChild("RobloxPromptGui")
    if promptGui then
        local promptFrame = promptGui:FindFirstChild("promptOverlay")
        if promptFrame and promptFrame.Visible == true then
            local errorPrompt = promptFrame:FindFirstChild("ErrorPrompt")
            if errorPrompt and errorPrompt.Visible == true then
                if PromptConnection then PromptConnection:Disconnect() end
                LocalServerHop()
            end
        end
    end
end)

